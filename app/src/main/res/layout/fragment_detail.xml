<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#FFE8D0">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Detail Fragment"
        android:textSize="24sp"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginBottom="32dp"
        android:textColor="#888888"
        android:text="b/403993348 — fragment unknown to FragmentNavigator"/>

    <Button
        android:id="@+id/btn_trigger_crash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="▶  Trigger crash (button)"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_arm_gesture"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎯  Arm for gesture, then swipe back"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:gravity="center"
        android:text="Status: waiting..."/>

</LinearLayout>
